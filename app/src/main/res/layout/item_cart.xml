<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
   xmlns:app="http://schemas.android.com/apk/res-auto"
   android:layout_width="match_parent"
   android:layout_height="wrap_content"
   android:layout_marginVertical="5dp"
   app:cardCornerRadius="8dp"
   app:cardElevation="2dp">


   <LinearLayout
       android:layout_width="match_parent"
       android:layout_height="wrap_content"
       android:orientation="horizontal"
       android:padding="10dp"
       android:gravity="center_vertical"
       android:weightSum="10">


       <ImageView
           android:id="@+id/ivCartImage"
           android:layout_width="0dp"
           android:layout_height="50dp"
           android:layout_weight="2"
           android:scaleType="centerCrop"
           android:src="@mipmap/ic_launcher" />


       <LinearLayout
           android:layout_width="0dp"
           android:layout_height="wrap_content"
           android:layout_weight="3"
           android:orientation="vertical"
           android:paddingHorizontal="5dp">


           <TextView
               android:id="@+id/tvCartName"
               android:layout_width="match_parent"
               android:layout_height="wrap_content"
               android:text="Product"
               android:textSize="12sp"
               android:textStyle="bold"
               android:textColor="#333" />


           <TextView
               android:id="@+id/tvCartPrice"
               android:layout_width="match_parent"
               android:layout_height="wrap_content"
               android:text="₱0.00"
               android:textSize="12sp"
               android:textColor="#666" />
       </LinearLayout>


       <EditText
           android:id="@+id/etCartQuantity"
           android:layout_width="0dp"
           android:layout_height="40dp"
           android:layout_weight="1.5"
           android:inputType="number"
           android:text="1"
           android:gravity="center"
           android:background="@android:drawable/edit_text"
           android:textSize="12sp"/>


       <Button
           android:id="@+id/btnUpdateCart"
           android:layout_width="0dp"
           android:layout_height="40dp"
           android:layout_weight="1"
           android:text="✓"
           android:textColor="#FFFFFF"
           android:backgroundTint="#28A745"
           android:textSize="12sp"
           android:padding="0dp"/>


       <TextView
           android:id="@+id/tvCartSubtotal"
           android:layout_width="0dp"
           android:layout_height="wrap_content"
           android:layout_weight="1.5"
           android:text="₱0.00"
           android:textSize="12sp"
           android:textStyle="bold"
           android:textColor="#333"
           android:gravity="center"/>


       <Button
           android:id="@+id/btnRemoveCart"
           android:layout_width="0dp"
           android:layout_height="40dp"
           android:layout_weight="1"
           android:text="X"
           android:textColor="#E1306C"
           android:backgroundTint="#FFFFFF"
           android:textSize="10sp"
           android:padding="0dp"/>


   </LinearLayout>
</androidx.cardview.widget.CardView>
