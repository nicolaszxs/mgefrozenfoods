<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp">
            <TextView
                android:id="@+id/tvOrderId"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Order #1"
                android:textSize="18sp"
                android:textColor="#0D6EFD"
                android:textStyle="bold"/>
            <TextView
                android:id="@+id/tvCurrentStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentRight="true"
                android:text="Pending"
                android:textColor="#DC3545"
                android:textStyle="bold"/>
        </RelativeLayout>

        <TextView
            android:id="@+id/tvCustomerName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Customer Name"
            android:textStyle="bold"
            android:textColor="#333333"
            android:textSize="16sp"/>

        <TextView
            android:id="@+id/tvContactAddress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Address / Contact"
            android:textSize="12sp"
            android:textColor="#6C757D"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Items Ordered:"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#333333"/>

        <TextView
            android:id="@+id/tvItemsOrdered"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="1x Bacon, 2x Purefoods Hotdog"
            android:textSize="14sp"
            android:textColor="#000000"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvPaymentTotal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="COD - Total: ₱0.00"
            android:textStyle="bold"
            android:textColor="#198754"
            android:textSize="16sp"
            android:layout_marginBottom="16dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Update:"
                android:textSize="14sp"
                android:textColor="#333333"
                android:layout_marginEnd="8dp"/>

            <Spinner
                android:id="@+id/spinStatus"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="45dp"
                android:background="@android:drawable/btn_dropdown"/>

            <Button
                android:id="@+id/btnSaveStatus"
                android:layout_width="wrap_content"
                android:layout_height="45dp"
                android:text="SAVE"
                android:backgroundTint="#0D6EFD"
                android:layout_marginStart="8dp"/>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>